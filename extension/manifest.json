{
  "manifest_version": 3,
  "name": "営業手帳 会社名追加",
  "version": "0.1.0",
  "description": "Webページで選択した会社名を右クリックから営業手帳へ追加します。",
  "permissions": ["contextMenus", "notifications", "tabs"],
  "host_permissions": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "営業手帳"
  }
}
