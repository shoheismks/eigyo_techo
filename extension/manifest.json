{
  "manifest_version": 3,
  "name": "営業手帳 会社名追加",
  "version": "0.1.1",
  "description": "Webページで選択した会社名を右クリックから営業手帳へ追加します。",
  "permissions": ["contextMenus", "notifications", "tabs"],
  "host_permissions": ["https://eigyo-techo.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://eigyo-techo.vercel.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "営業手帳"
  }
}
